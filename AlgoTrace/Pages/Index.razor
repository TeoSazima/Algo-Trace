@page "/"

<div class="dashboard-wrapper">

    <section class="hero-section row align-items-center g-5">
        <div class="col-lg-6">
            <span class="badge-precision text-uppercase">Engineered for precision</span>
            <h1 class="hero-title mt-2 mb-3">Master algorithms through interactive visualization.</h1>
            <p class="hero-desc text-muted">
                Deconstruct complex logic into pixel-perfect visual traces. Experience algorithms as dynamic flows, not static code.
            </p>
        </div>
        <div class="col-lg-6 d-flex justify-content-center">
            <div class="hero-chart-card">
                <div class="chart-header">
                    <div class="window-dots">
                        <span></span><span></span><span></span>
                    </div>
                    <span class="chart-title">Bubble Sort Trace</span>
                </div>
                <div class="chart-bars">
                    <div class="hero-bar" style="height: 40px;"></div>
                    <div class="hero-bar" style="height: 100px;"></div>
                    <div class="hero-bar hero-bar-dark" style="height: 150px;"><span class="bar-lbl">38</span></div>
                    <div class="hero-bar" style="height: 60px;"></div>
                    <div class="hero-bar hero-bar-dark" style="height: 110px;"><span class="bar-lbl">32</span></div>
                    <div class="hero-bar" style="height: 130px;"></div>
                    <div class="hero-bar" style="height: 75px;"></div>
                    <div class="hero-bar" style="height: 30px;"></div>
                </div>
            </div>
        </div>
    </section>

    <section class="steps-section text-center">
        <h2 class="section-title">Scientific Logic, Simply Visualized</h2>
        <p class="text-muted small">Three steps to algorithmic enlightenment.</p>

        <div class="steps-container mt-5">
            <div class="steps-line d-none d-md-block"></div>

            <div class="row g-4 position-relative">
                <div class="col-md-4">
                    <div class="step-card">
                        <div class="step-icon">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <h4 class="step-name">Choose an algorithm</h4>
                        <p class="step-text text-muted">Select from our extensive library of sorting, pathfinding, or dynamic structures.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step-card">
                        <div class="step-icon">
                            <i class="bi bi-sliders"></i>
                        </div>
                        <h4 class="step-name">Set parameters</h4>
                        <p class="step-text text-muted">Adjust data size, execution speed, and edge cases to see how the logic responds.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step-card">
                        <div class="step-icon">
                            <i class="bi bi-eye"></i>
                        </div>
                        <h4 class="step-name">Watch logic unfold</h4>
                        <p class="step-text text-muted">Track execution step-by-step with real-time complexity analysis and logic flows.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="libraries-section">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h3 class="fw-bold mb-1">Explore Libraries</h3>
                <p class="text-muted small mb-0">Deep dive into specific computational categories.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-3 col-md-6">
                <div class="lib-card">
                    <div class="lib-icon-wrapper"><i class="bi bi-filter-left"></i></div>
                    <h4 class="lib-title">Sorting</h4>
                    <p class="lib-desc text-muted">Bubble, Quick, Merge, and advanced distribution sorts.</p>
                    <div class="lib-tags mt-auto">
                        <span class="lib-tag">O(N LOG N)</span>
                        <span class="lib-tag">STABLE</span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="lib-card">
                    <div class="lib-icon-wrapper"><i class="bi bi-signpost-split"></i></div>
                    <h4 class="lib-title">Pathfinding</h4>
                    <p class="lib-desc text-muted">A*, Dijkstra, and BFS/DFS traversal explorations.</p>
                    <div class="lib-tags mt-auto">
                        <span class="lib-tag">GRAPHS</span>
                        <span class="lib-tag">HEURISTIC</span>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="lib-card">
                    <div class="lib-icon-wrapper"><i class="bi bi-diagram-2"></i></div>
                    <h4 class="lib-title">Graphs</h4>
                    <p class="lib-desc text-muted">Visualise graphs...</p>
                    <div class="lib-tags mt-auto">
                        <span class="lib-tag">STORAGE</span>
                        <span class="lib-tag">MEMO</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>