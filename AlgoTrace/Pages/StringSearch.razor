@page "/strings/{slug}"

@using AlgoTrace.Models
@using AlgoTrace.Services

@inject StringAlgorithmService StringAlgoService
@inject StringSearchService StringSearchSvc
@inject NavigationManager Navigation

<div class="sorting-container">
    @if (CurrentAlgorithm == null)
    {
        <div class="alert alert-warning">
            <h4>Algorithm not found</h4>
            <p>Please select a valid algorithm from the menu.</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-3">
                <h2 class="fw-bold mb-0">@CurrentAlgorithm.Name</h2>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill small"
                      style="font-size: 0.75rem;">
                    Status: @GetProcessStatus();
                </span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;"
                        @onclick="SimulationButton"
                        disabled="@(GetProcessStatus() == "Done")">
                    @if (_isRunning)
                    {
                        <i class="bi bi-pause-fill fs-5"></i>
                    }
                    else
                    {
                        <i class="bi bi-play-fill fs-5"></i>
                    }
                </button>
                <button class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;"
                        @onclick="ApplyAndRestart">
                    <i class="bi bi-arrow-counterclockwise fs-5"></i>
                </button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">


                <div class="card border-0 shadow-sm p-4 mb-4"
                     style="background: #ffffff; border-radius: 12px; min-height: 220px;">

                    @if (_currentStep != null)
                    {

                        <div class="mb-3">
                            <div class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em; font-size:.68rem;">
                                <i class="bi bi-file-text me-1"></i>Text
                            </div>
                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                @for (int i = 0; i < _currentStep.Text.Length; i++)
                                {
                                    int idx = i;
                                    bool isActiveText = idx == _currentStep.TextIndex;
                                    bool isInWindow = _currentStep.WindowStart >= 0
                                        && idx >= _currentStep.WindowStart
                                        && idx < _currentStep.WindowStart + _currentStep.Pattern.Length;
                                    bool isFound = _currentStep.FoundPositions.Contains(_currentStep.WindowStart)
                                        && isInWindow && _currentStep.IsFound;
                                    bool isPrevFound = _currentStep.FoundPositions.Any(fp => idx >= fp && idx < fp + _currentStep.Pattern.Length)
                                        && !isActiveText;

                                    string bg = isFound ? "#86efac"
                                        : isActiveText && _currentStep.IsMatch ? "#bbf7d0"
                                        : isActiveText && _currentStep.IsMismatch ? "#fecaca"
                                        : isActiveText ? "#bfdbfe"
                                        : isInWindow ? "#dbeafe"
                                        : isPrevFound ? "#d1fae5"
                                        : "#f3f4f6";

                                    string border = isActiveText ? "2px solid #0b57d0"
                                        : isInWindow ? "1px solid #93c5fd"
                                        : "1px solid transparent";

                                    <div style="width:32px; height:36px; background:@bg; border:@border;
                                                border-radius:6px; display:flex; flex-direction:column;
                                                align-items:center; justify-content:center; transition: background .15s;">
                                        <span style="font-size:.85rem; font-family:'Fira Code',monospace; font-weight: @(isActiveText ? "bold" : "normal");">
                                            @_currentStep.Text[idx]
                                        </span>
                                        <span style="font-size:.55rem; color:#9ca3af;">@idx</span>
                                    </div>
                                }
                            </div>
                        </div>


                        <div class="mb-3">
                            <div class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em; font-size:.68rem;">
                                <i class="bi bi-search me-1"></i>Pattern
                            </div>
                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                @{
                                    int offset = Math.Max(0, _currentStep.WindowStart);
                                }
                                @for (int s = 0; s < offset; s++)
                                {
                                    <div style="width:32px; height:36px;"></div>
                                }
                                @for (int j = 0; j < _currentStep.Pattern.Length; j++)
                                {
                                    int pidx = j;
                                    bool isActiveP = pidx == _currentStep.PatternIndex;
                                    string pbg = isActiveP && _currentStep.IsMatch ? "#bbf7d0"
                                        : isActiveP && _currentStep.IsMismatch ? "#fecaca"
                                        : isActiveP ? "#bfdbfe"
                                        : "#f3f4f6";
                                    string pborder = isActiveP ? "2px solid #0b57d0" : "1px solid transparent";

                                    <div style="width:32px; height:36px; background:@pbg; border:@pborder;
                                                border-radius:6px; display:flex; flex-direction:column;
                                                align-items:center; justify-content:center; transition: background .15s;">
                                        <span style="font-size:.85rem; font-family:'Fira Code',monospace; font-weight: @(isActiveP ? "bold" : "normal");">
                                            @_currentStep.Pattern[pidx]
                                        </span>
                                        <span style="font-size:.55rem; color:#9ca3af;">@pidx</span>
                                    </div>
                                }
                            </div>
                        </div>


                        @if (_currentStep.KmpTable != null)
                        {
                            <div class="mb-3">
                                <div class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing:.05em; font-size:.68rem;">
                                    <i class="bi bi-table me-1"></i>LPS Failure Table
                                </div>
                                <div class="d-flex gap-1 flex-wrap">
                                    @for (int k = 0; k < _currentStep.KmpTable.Length; k++)
                                    {
                                        int ki = k;
                                        <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                                            <div style="width:28px; height:28px; background:#f3f4f6; border-radius:4px;
                                                        display:flex; align-items:center; justify-content:center;
                                                        font-size:.75rem; font-family:'Fira Code',monospace; color:#374151;">
                                                @_currentStep.Pattern[ki]
                                            </div>
                                            <div style="width:28px; height:24px; background:#dbeafe; border-radius:4px;
                                                        display:flex; align-items:center; justify-content:center;
                                                        font-size:.7rem; font-weight:bold; color:#0b57d0;">
                                                @_currentStep.KmpTable[ki]
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }


                        @if (_currentStep.PatternHash >= 0)
                        {
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="px-3 py-2 rounded" style="background:#f3f4f6; font-size:.78rem;">
                                    <span class="text-muted">Pattern hash: </span>
                                    <span class="fw-bold" style="font-family:'Fira Code',monospace;">@_currentStep.PatternHash</span>
                                </div>
                                <div class="px-3 py-2 rounded" style="background: @(_currentStep.TextHash == _currentStep.PatternHash ? "#bbf7d0" : "#f3f4f6"); font-size:.78rem;">
                                    <span class="text-muted">Window hash: </span>
                                    <span class="fw-bold" style="font-family:'Fira Code',monospace;">@_currentStep.TextHash</span>
                                </div>
                            </div>
                        }


                        <div class="mt-3 px-3 py-2 rounded d-flex align-items-center gap-2"
                             style="background: @(_currentStep.IsFound ? "#d1fae5" : _currentStep.IsMismatch ? "#fee2e2" : "#f0f9ff"); font-size:.82rem; color:#374151;">
                            <i class="bi @(_currentStep.IsFound ? "bi-check-circle-fill text-success" : _currentStep.IsMismatch ? "bi-x-circle-fill text-danger" : "bi-info-circle text-primary")"></i>
                            @_currentStep.StatusMessage
                        </div>


                        @if (_currentStep.FoundPositions.Count > 0)
                        {
                            <div class="mt-2 d-flex gap-2 align-items-center flex-wrap">
                                <span class="text-muted small">Matches found at:</span>
                                @foreach (var pos in _currentStep.FoundPositions)
                                {
                                    <span class="badge" style="background:#86efac; color:#166534; font-size:.75rem;">@pos</span>
                                }
                            </div>
                        }
                    }
                </div>


                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm p-4 h-100"
                             style="background: #0d1527; color: #f8fafc; border-radius: 12px;">
                            <h6 class="text-uppercase text-muted fw-bold mb-3"
                                style="font-size: 0.7rem; letter-spacing: 0.05em;">
                                <i class="bi bi-code-slash me-1"></i> Pseudocode
                            </h6>
                            <div style="font-family: 'Fira Code', monospace; font-size: 0.82rem; line-height: 1.6;">
                                @if (CurrentAlgorithm.Pseudocode != null)
                                {
                                    @foreach (var line in CurrentAlgorithm.Pseudocode)
                                    {
                                        <div class="@(line.IsKeyword ? "text-danger fw-bold" : line.IsComment ? "text-secondary" : "")">
                                            @line.Text
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm p-4 h-100"
                             style="background: #ffffff; border-radius: 12px;">
                            <h6 class="text-uppercase text-muted fw-bold mb-3"
                                style="font-size: 0.7rem; letter-spacing: 0.05em;">
                                <i class="bi bi-diagram-3 me-1"></i> Logic Flow
                            </h6>
                            <div class="d-flex flex-column gap-2">
                                @if (CurrentAlgorithm.LogicFlow != null)
                                {
                                    @foreach (var step in CurrentAlgorithm.LogicFlow)
                                    {
                                        <div class="p-2 rounded border d-flex align-items-start gap-2
                                                        @(step.Number == _currentStep?.LogicFlowIndex ? "border-primary bg-primary-subtle" : "border-light-subtle")">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center
                                                            @(step.Number == _currentStep?.LogicFlowIndex ? "bg-primary text-white" : "bg-light text-muted")"
                                                 style="width: 24px; height: 24px; min-width: 24px; font-size: 0.75rem;">
                                                @step.Number
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@step.Title</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">@step.Description</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                {{!-- COMPLEXITY --}}
                <div class="card border-0 shadow-sm p-4"
                     style="background: #ffffff; border-radius: 12px;">
                    <h6 class="text-uppercase text-muted fw-bold mb-3"
                        style="font-size: 0.7rem; letter-spacing: 0.05em;">
                        <i class="bi bi-bar-chart me-1"></i> Complexity Analysis
                    </h6>
                    <div class="row g-4 align-items-center">
                        <div class="col-md-7 border-end border-light-subtle">
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Best Case Time</div>
                                    <div class="fs-4 fw-bold text-primary">@CurrentAlgorithm.TimeComplexityBest</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Worst Case Time</div>
                                    <div class="fs-4 fw-bold text-danger">@CurrentAlgorithm.TimeComplexityWorst</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Space Complexity</div>
                                    <div class="fs-4 fw-bold text-dark">@CurrentAlgorithm.SpaceComplexity</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 ps-md-4">
                            <p class="text-muted mb-0" style="font-size: 0.85rem; line-height: 1.5;">
                                @CurrentAlgorithm.Description
                            </p>
                        </div>
                    </div>
                </div>

            </div>


            <div class="col-lg-4">
                <div class="card border-0 shadow-sm p-4"
                     style="background: #ffffff; border-radius: 12px;">
                    <h6 class="text-uppercase text-muted fw-bold mb-3"
                        style="font-size: 0.7rem; letter-spacing: 0.05em;">
                        Configuration
                    </h6>

                    <div class="mb-3">
                        <label class="form-label text-muted small mb-1">Text</label>
                        <input type="text" class="form-control bg-light-subtle border-light-subtle"
                               style="font-size: 0.85rem; font-family: 'Fira Code', monospace;"
                               @bind="_inputText" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small mb-1">Pattern</label>
                        <input type="text" class="form-control bg-light-subtle border-light-subtle"
                               style="font-size: 0.85rem; font-family: 'Fira Code', monospace;"
                               @bind="_inputPattern" />
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">Simulation Delay</span>
                            <span class="badge bg-light text-dark border border-light-subtle px-2 py-1">
                                @SimulationDelay ms
                            </span>
                        </div>
                        <input type="range" class="form-range"
                               min="100" max="1500" step="50"
                               @bind="SimulationDelay"
                               @bind:event="oninput" />
                    </div>

                    <button class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2 fw-bold"
                            style="border-radius: 8px; font-size: 0.9rem;"
                            @onclick="ApplyAndRestart">
                        <i class="bi bi-rocket-takeoff-fill"></i> Apply
                    </button>


                    <div class="mt-4">
                        <div class="text-muted small fw-bold text-uppercase mb-2" style="font-size:.68rem; letter-spacing:.05em;">Legend</div>
                        <div class="d-flex flex-column gap-1" style="font-size:.78rem;">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:16px;height:16px;background:#dbeafe;border-radius:3px;border:1px solid #93c5fd;"></div>
                                <span class="text-muted">Current window</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:16px;height:16px;background:#bbf7d0;border-radius:3px;"></div>
                                <span class="text-muted">Character match</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:16px;height:16px;background:#fecaca;border-radius:3px;"></div>
                                <span class="text-muted">Mismatch</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:16px;height:16px;background:#86efac;border-radius:3px;"></div>
                                <span class="text-muted">Full match found</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Slug { get; set; }

    private AlgorithmData? CurrentAlgorithm { get; set; }
    private int SimulationDelay { get; set; } = 400;

    private string _inputText = "abacababcabab";
    private string _inputPattern = "abab";
    private List<StringStep> _steps = new();
    private StringStep? _currentStep;
    private int _stepIndex = 0;
    private bool _isRunning = false;

    protected override void OnParametersSet()
    {
        string activeSlug = Slug?.ToLower() ?? "naive";
        CurrentAlgorithm = StringAlgoService.GetBySlug(activeSlug);
        ApplyAndRestart();
    }

    private void ApplyAndRestart()
    {
        _isRunning = false;
        _stepIndex = 0;
        string slug = Slug?.ToLower() ?? "naive";
        _steps = StringSearchSvc.GenerateSteps(slug, _inputText.Trim(), _inputPattern.Trim());
        _currentStep = _steps.FirstOrDefault();
    }

    private async Task SimulationButton()
    {
        if (!_isRunning)
        {
            _isRunning = true;
            while (_stepIndex < _steps.Count - 1 && _isRunning)
            {
                _stepIndex++;
                _currentStep = _steps[_stepIndex];
                StateHasChanged();
                await Task.Delay(SimulationDelay);
            }
            _isRunning = false;
        }
        else
        {
            _isRunning = false;
        }
    }

    private string GetProcessStatus()
    {
        if (!_isRunning && _stepIndex == 0) return "Ready";
        if (_isRunning && _stepIndex == _steps.Count - 1) return "Done";
        if (!_isRunning && _stepIndex != 0) return "Paused";
        if (_isRunning) return "Running";
        return "Ready";
    }
}
