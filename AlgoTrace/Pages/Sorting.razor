@page "/sorting/{slug}"

@using AlgoTrace.Models
@using AlgoTrace.Services

@inject AlgorithmService AlgoService
@inject SortingService SortingSvc
@inject NavigationManager Navigation

<div class="sorting-container">
    @if (CurrentAlgorithm == null)
    {
        <div class="alert alert-warning">
            <h4>Algorithm not found</h4>
            <p>Please select a valid algorithm from the menu on the left.</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-3">
                <h2 class="fw-bold mb-0">@CurrentAlgorithm.Name</h2>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill small"
                      style="font-size: 0.75rem;">
                    Status: @GetProcessStatus();
                </span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;"
                    @onclick="SimulationButton";
                    disabled="@(GetProcessStatus() == "Done")"
                    
                >
                    
                    @if(_isRunning)
                    {
                        <i class="bi bi-pause-fill fs-5"></i>
                        
                        
                    }
                    else
                    {
                        <i class="bi bi-play-fill fs-5"></i>
                    }                   
                </button>

                <button class="btn btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;"
                        @onclick="ApplyAndRestart">
                    <i class="bi bi-arrow-counterclockwise fs-5"></i>
                </button>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-8">

                <div class="card border-0 shadow-sm p-4 mb-4"
                     style="background: #ffffff; border-radius: 12px; min-height: 280px;">
                    <div class="chart-container d-flex align-items-flex-end justify-content-center gap-2"
                         style="height: 220px;">

                        @if (_currentStep != null)
                        {
                            int maxVal = _currentStep.Array.Max();

                            for (int i = 0; i < _currentStep.Array.Length; i++)
                            {
                                int val = _currentStep.Array[i];
                                int heightPx = (int)(val / (double)maxVal * 200);
                                bool isActive = i == _currentStep.CompareIndexA
                                || i == _currentStep.CompareIndexB;
                                bool isSorted = i >= _currentStep.SortedUpToIndex
                                && _currentStep.SortedUpToIndex >= 0;

                                string bg = isActive ? "#0b57d0"
                                : isSorted ? "#86efac"
                                : "#bfdbfe";

                                <div style="height: @(heightPx)px; width: 24px;
                                                        background: @bg;
                                                        border-radius: 4px;
                                                        position: relative;
                                                        transition: height 0.15s ease;">
                                    <span class="position-absolute w-100 text-center"
                                          style="top: @(isActive ? "8px" : "-20px");
                                                             font-size: 0.75rem;
                                                             color: @(isActive ? "white" : "#6b7280");
                                                             font-weight: @(isActive ? "bold" : "normal");">
                                        @val
                                    </span>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm p-4 h-100"
                             style="background: #0d1527; color: #f8fafc; border-radius: 12px;">
                            <h6 class="text-uppercase text-muted fw-bold mb-3"
                                style="font-size: 0.7rem; letter-spacing: 0.05em;">
                                <i class="bi bi-code-slash me-1"></i> Pseudocode
                            </h6>
                            <div style="font-family: 'Fira Code', monospace; font-size: 0.85rem; line-height: 1.6;">
                                @if (CurrentAlgorithm.Pseudocode != null)
                                {
                                    @foreach (var line in CurrentAlgorithm.Pseudocode)
                                    {
                                        <div class="@(line.IsKeyword ? "text-danger fw-bold" : line.IsComment ? "text-secondary" : "")">
                                            @line.Text
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm p-4 h-100"
                             style="background: #ffffff; border-radius: 12px;">
                            <h6 class="text-uppercase text-muted fw-bold mb-3"
                                style="font-size: 0.7rem; letter-spacing: 0.05em;">
                                <i class="bi bi-diagram-3 me-1"></i> Logic Flow
                            </h6>
                            <div class="d-flex flex-column gap-2">
                                @if (CurrentAlgorithm.LogicFlow != null)
                                {
                                    @foreach (var step in CurrentAlgorithm.LogicFlow)
                                    {
                                        <div class="p-2 rounded border @(step.Number == 2 ? "border-primary bg-primary-subtle" : "border-light-subtle") d-flex gap-3 align-items-center"
                                             style="font-size: 0.85rem;">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold @(step.Number == 2 ? "bg-primary text-white" : "bg-light text-muted")"
                                                 style="width: 24px; height: 24px; min-width: 24px; font-size: 0.75rem;">
                                                @step.Number
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@step.Title</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">@step.Description</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm p-4"
                     style="background: #ffffff; border-radius: 12px;">
                    <h6 class="text-uppercase text-muted fw-bold mb-3"
                        style="font-size: 0.7rem; letter-spacing: 0.05em;">
                        <i class="bi bi-bar-chart me-1"></i> Complexity Analysis
                    </h6>
                    <div class="row g-4 align-items-center">
                        <div class="col-md-7 border-end border-light-subtle">
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Best Case Time</div>
                                    <div class="fs-4 fw-bold text-primary">@CurrentAlgorithm.TimeComplexityBest</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Worst Case Time</div>
                                    <div class="fs-4 fw-bold text-danger">@CurrentAlgorithm.TimeComplexityWorst</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted mb-1">Space Complexity</div>
                                    <div class="fs-4 fw-bold text-dark">@CurrentAlgorithm.SpaceComplexity</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 ps-md-4">
                            <p class="text-muted mb-0"
                               style="font-size: 0.85rem; line-height: 1.5;">
                                @CurrentAlgorithm.Description
                            </p>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm p-4"
                     style="background: #ffffff; border-radius: 12px;">
                    <h6 class="text-uppercase text-muted fw-bold mb-3"
                        style="font-size: 0.7rem; letter-spacing: 0.05em;">
                        Configuration
                    </h6>

                    <div class="mb-4">
                        <label class="form-label text-muted small mb-1">Data Input (CSV)</label>
                        @* Přidej do <head> nebo na začátek souboru - skrytý file input *@
                        <InputFile id="csvFileInput" accept=".csv" OnChange="HandleFileUpload" style="display:none;" />

                        <div class="mb-4">
                            <label class="form-label text-muted small mb-1"></label>
                            <div class="input-group">
                                <input type="text"
                                       class="form-control bg-light-subtle border-light-subtle"
                                       style="font-size: 0.85rem;"
                                       @bind="_inputCsv" />

                                <label for="csvFileInput"
                                       class="btn btn-outline-secondary border-light-subtle bg-light text-muted d-flex align-items-center gap-1"
                                       style="font-size: 0.85rem; cursor: pointer; margin-bottom: 0;">
                                    <i class="bi bi-file-earmark-arrow-up"></i> Import
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small">Simulation Delay</span>
                            <span class="badge bg-light text-dark border border-light-subtle px-2 py-1">
                                @SimulationDelay ms
                            </span>
                        </div>
                        <input type="range" class="form-range"
                               min="100" max="1000" step="50"
                               @bind="SimulationDelay"
                               @bind:event="oninput" />
                    </div>

                    <button class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2 fw-bold"
                            style="border-radius: 8px; font-size: 0.9rem;"
                            @onclick="ApplyAndRestart">
                        <i class="bi bi-rocket-takeoff-fill"></i> Apply & Restart
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter] public string? Slug { get; set; }

    private AlgorithmData? CurrentAlgorithm { get; set; }
    private int SimulationDelay { get; set; } = 300;

    private string _inputCsv = "12, 45, 32, 38, 8, 52, 25";
    private List<SortStep> _steps = new();
    private SortStep? _currentStep;
    private int _stepIndex = 0;
    private bool _isRunning = false;

    protected override void OnParametersSet()
    {
        string activeSlug = Slug?.ToLower() ?? "bubble";
        CurrentAlgorithm = AlgoService.GetAlgorithmBySlug(activeSlug);
        ApplyAndRestart();
    }

    private void ApplyAndRestart()
    {
        _isRunning = false;
        _stepIndex = 0;

        var numbers = _inputCsv
            .Split(',')
            .Select(s => int.TryParse(s.Trim(), out int n) ? n : -1)
            .Where(n => n > 0)
            .ToArray();

        string slug = Slug?.ToLower() ?? "bubble";
        _steps = SortingSvc.GenerateSteps(slug, numbers);
        _currentStep = _steps.FirstOrDefault();
    }

    private async Task SimulationButton()
    {

        if (!_isRunning)
        {
            _isRunning = true;
            while (_stepIndex < _steps.Count - 1 && _isRunning)
            {
                _stepIndex++;
                _currentStep = _steps[_stepIndex];
                StateHasChanged();
                await Task.Delay(SimulationDelay);
            }
        }
        else
        {
            _isRunning = false;
        }




    }



    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
            return;

        int maxSize = 1048576; // 1 MB
        using var stream = file.OpenReadStream(maxAllowedSize: maxSize); 
        using var reader = new System.IO.StreamReader(stream);
        var content = await reader.ReadToEndAsync();


        _inputCsv = content.Split('\n').FirstOrDefault()?.Trim() ?? string.Empty;
        ApplyAndRestart();
    }

    private string GetProcessStatus()
    {
        if(!_isRunning && _stepIndex != 0)
        {
            return "Paused";
            _isRunning = false;
        }
        else if (_isRunning && _stepIndex == _steps.Count - 1)
        {
            
            return "Done";

        }
        else if(_isRunning && _stepIndex != _steps.Count - 1)
        {
            return "Running";
        }
        else
        {
            return "Ready";
        }
    }
}
