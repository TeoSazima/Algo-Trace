@inherits LayoutComponentBase
@using AlgoTrace.Services
@inject NavigationManager Navigation
@inject StringAlgorithmService StringAlgorithmService
 
<div class="page-wrapper">
    
    <header class="top-navbar">
        <div class="navbar-brand">
            <h2 @onclick='() => Navigation.NavigateTo("")' style="cursor: pointer;">AlgoTrace</h2>
        </div>
 
        <nav class="top-nav-links d-none d-lg-flex">
            <NavLink class="top-nav-item" href="" Match="NavLinkMatch.All">Dashboard</NavLink>
            <NavLink class="top-nav-item" href="sorting/bubble">Sorting</NavLink>
            <NavLink class="top-nav-item" href="strings/naive">Strings</NavLink>
            <NavLink class="top-nav-item" href="pathfinding">Pathfinding</NavLink>
        </nav>
 
        <button class="burger-btn d-lg-none" @onclick="ToggleMobileMenu" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>
    </header>
 
    <div class="mobile-drawer @(isMobileMenuOpen ? "open" : "") d-lg-none">
        <div class="drawer-header">
            <h5 class="mb-0 fw-bold">Menu</h5>
            <button class="close-btn" @onclick="ToggleMobileMenu">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="drawer-content">

            <div class="drawer-row">
                <NavLink class="drawer-item" href="" Match="NavLinkMatch.All" @onclick="ToggleMobileMenu">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </NavLink>
            </div>

            <div class="drawer-row">
                <div class="drawer-accordion w-100">
                    <button class="drawer-item accordion-trigger @(isSortingExpanded ? "expanded" : "")" @onclick="ToggleSorting" type="button">
                        <span class="d-flex align-items-center">
                            <i class="bi bi-filter-left me-2"></i> Sorting
                        </span>
                        <i class="bi bi-chevron-down arrow-icon"></i>
                    </button>

                    <div class="accordion-menu @(isSortingExpanded ? "show" : "")">
                        @if (AlgorithmService.algorithms != null)
                        {
                            @foreach (var algo in AlgorithmService.algorithms)
                            {
                                <NavLink class="accordion-item" href="@($"sorting/{algo.Slug}")" @onclick="ToggleMobileMenu">
                                    <i class="bi bi-dot me-1"></i> @algo.Name
                                </NavLink>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="drawer-row">
                <div class="drawer-accordion w-100">
                    <button class="drawer-item accordion-trigger @(isStringsExpanded ? "expanded" : "")" @onclick="ToggleStrings" type="button">
                        <span class="d-flex align-items-center">
                            <i class="bi bi-fonts me-2"></i> Strings
                        </span>
                        <i class="bi bi-chevron-down arrow-icon"></i>
                    </button>

                    <div class="accordion-menu @(isStringsExpanded ? "show" : "")">
                        @foreach (var algo in StringAlgorithmService.algorithms)
                        {
                            <NavLink class="accordion-item" href="@($"strings/{algo.Slug}")" @onclick="ToggleMobileMenu">
                                <i class="bi bi-dot me-1"></i> @algo.Name
                            </NavLink>
                        }
                    </div>
                </div>
            </div>

            <div class="drawer-row">
                <NavLink class="drawer-item" href="pathfinding" @onclick="ToggleMobileMenu">
                    <i class="bi bi-signpost-split me-2"></i> Pathfinding
                </NavLink>
            </div>

        </div>
    </div>
 
    @if (isMobileMenuOpen)
    {
        <div class="drawer-overlay d-lg-none" @onclick="ToggleMobileMenu"></div>
    }
 
    <div class="main-layout-body">
        
        @if (ShowSidebar)
        {
            <aside class="sidebar d-none d-lg-block">
                <nav class="sidebar-nav">
                    <div class="nav-section">
                        @if (Navigation.Uri.Contains("/sorting/", StringComparison.OrdinalIgnoreCase))
                        {
                            @foreach (var algo in AlgorithmService.algorithms)
                            {
                                <NavLink class="sidebar-item" href="@($"sorting/{algo.Slug}")">@algo.Name</NavLink>
                            }
                        }
                        else if (Navigation.Uri.Contains("/strings/", StringComparison.OrdinalIgnoreCase))
                        {
                            @foreach (var algo in StringAlgorithmService.algorithms)
                            {
                                <NavLink class="sidebar-item" href="@($"strings/{algo.Slug}")">@algo.Name</NavLink>
                            }
                        }
                    </div>
                </nav>
            </aside>
        }
 
        <main class="main-content @(ShowSidebar ? "has-sidebar" : "")">
            <div class="content-container">
                @Body
            </div>
            <footer class="content-footer text-center">
                AlgoTrace Systems &copy; 2026. Precision Engineering.
            </footer>
        </main>
    </div>
</div>
 
@code {
    private bool isMobileMenuOpen = false;
    private bool isSortingExpanded = false;
    private bool isStringsExpanded = false;

    private bool ShowSidebar =>
        Navigation.Uri.Contains("/sorting/", StringComparison.OrdinalIgnoreCase)
        || Navigation.Uri.Contains("/strings/", StringComparison.OrdinalIgnoreCase);

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private void ToggleSorting()
    {
        isSortingExpanded = !isSortingExpanded;
    }

    private void ToggleStrings()
    {
        isStringsExpanded = !isStringsExpanded;
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += (s, e) => { isMobileMenuOpen = false; StateHasChanged(); };
    }
}
