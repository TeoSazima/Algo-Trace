FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY ["AlgoTrace.csproj", "./"]
RUN dotnet restore "AlgoTrace.csproj"
COPY . .
RUN dotnet publish "AlgoTrace.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "AlgoTrace.dll"]






docker build -t europe-west3-docker.pkg.dev/coba-studteam-3-mm/build/algotrace:v1 .



docker push europe-west3-docker.pkg.dev/coba-studteam-3-mm/build/algotrace:v1


